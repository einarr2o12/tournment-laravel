# =============================================================================
# Railway production environment template — tournment-laravel
#
# Two Railway services share ONE Docker image (this repo):
#   1. WEB     — nginx + php-fpm (Inertia/Vue app, HTTP)        -> start-web.sh
#   2. REVERB  — Laravel Reverb websocket server                -> start-reverb.sh
# Plus a managed Postgres plugin.
#
# Set the vars below in each service's Variables tab. Lines marked
# [WEB], [REVERB], or [BOTH] indicate where each var belongs.
#
# Railway template references use the ${{ Service.VAR }} syntax — paste them
# verbatim into the Railway dashboard; Railway resolves them at deploy time.
# =============================================================================


# ----------------------------------------------------------------------------
# [BOTH] Core app
# ----------------------------------------------------------------------------
APP_NAME=Tournment
APP_ENV=production
# Generate locally with `php artisan key:generate --show` and paste the
# `base64:...` value. Set the SAME key on BOTH services. Do NOT regenerate
# per deploy — it would invalidate sessions and encrypted data.
APP_KEY=
APP_DEBUG=false
# Public URL of the WEB service (its Railway-generated or custom domain).
APP_URL=https://WEB_DOMAIN
# Serve compiled Vite assets from the same web domain.
ASSET_URL=https://WEB_DOMAIN

# Log to stderr so Railway captures logs (no file logging on ephemeral fs).
LOG_CHANNEL=stderr
LOG_LEVEL=info


# ----------------------------------------------------------------------------
# [BOTH] Database (managed Railway Postgres plugin)
# ----------------------------------------------------------------------------
DB_CONNECTION=pgsql

# ---- Option A (SIMPLEST): single URL reference -----------------------------
# config/database.php reads DB_URL and parses host/port/db/user/pass from it.
# Railway's Postgres plugin exposes DATABASE_URL. Reference it like so:
DB_URL=${{Postgres.DATABASE_URL}}

# ---- Option B: map individual Postgres vars (use INSTEAD of DB_URL) --------
# Comment out DB_URL above and uncomment these if you prefer explicit vars:
# DB_HOST=${{Postgres.PGHOST}}
# DB_PORT=${{Postgres.PGPORT}}
# DB_DATABASE=${{Postgres.PGDATABASE}}
# DB_USERNAME=${{Postgres.PGUSER}}
# DB_PASSWORD=${{Postgres.PGPASSWORD}}

# SSL: 'prefer' works for Railway's private network. Use 'disable' if you hit
# SSL errors on the internal host, or 'require' for the public proxy host.
DB_SSLMODE=prefer


# ----------------------------------------------------------------------------
# [BOTH] DB-backed sessions / cache / queue (migrations create these tables)
# ----------------------------------------------------------------------------
SESSION_DRIVER=database
# HTTPS only — Railway terminates TLS at its proxy (trustProxies '*' is set).
SESSION_SECURE_COOKIE=true
# Leave blank unless you use a shared parent domain across subdomains.
SESSION_DOMAIN=
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=database

# Sanctum stateful domain = the web domain (no scheme, no trailing slash).
SANCTUM_STATEFUL_DOMAINS=WEB_DOMAIN


# ----------------------------------------------------------------------------
# [BOTH] Broadcasting / Reverb
# ----------------------------------------------------------------------------
BROADCAST_CONNECTION=reverb

# App credentials — identical on BOTH services (web publishes, reverb serves,
# frontend authenticates with the public key). Generate strong random values.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=

# Public reverb host the BROWSER connects to = the REVERB service's domain.
# The web service shares this to the frontend via Inertia props at runtime,
# so the reverb domain is NOT baked into the Vite build.
REVERB_HOST=REVERB_DOMAIN
REVERB_PORT=443
REVERB_SCHEME=https


# ----------------------------------------------------------------------------
# [REVERB ONLY] Server bind
# ----------------------------------------------------------------------------
# The reverb SERVER binds 0.0.0.0:$PORT on the REVERB service. start-reverb.sh
# passes --host=0.0.0.0 --port=$PORT, so these are informational; Railway
# injects $PORT automatically. If you prefer env over CLI flags:
# REVERB_SERVER_HOST=0.0.0.0
# REVERB_SERVER_PORT=${{PORT}}
